generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String      @id @default(cuid())
  name           String?
  email          String      @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String      @default("USER") // "USER" or "ADMIN"
  dob            DateTime
  anniversary    DateTime?
  gender         String      @default("other") // "male", "female", "other"
  address        String? // JSON string for address
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  accounts               Account[]
  sessions               Session[]
  events                 Event[]
  lists                  List[]
  notifications          Notification[]
  sentFriendRequests     Friendship[] @relation("requester")
  receivedFriendRequests Friendship[] @relation("addressee")
  itemsHeld              ListItem[]
  itemBlocks             ItemBlock[] @relation("itemBlocks")
  socialActivities       SocialActivity[] @relation("socialActivities")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      String @default("PENDING") // "PENDING", "ACCEPTED", "DECLINED", "BLOCKED"
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("requester", fields: [requesterId], references: [id])
  addressee User @relation("addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  name        String
  occasion    String // e.g., "Birthday", "Anniversary"
  eventDate   DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists List[]

  @@index([userId])
  @@index([eventDate])
}

model List {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event?     @relation(fields: [eventId], references: [id])
  items ListItem[]

  @@index([userId])
  @@index([eventId])
}

model ListItem {
  id           String         @id @default(cuid())
  listId       String
  productName  String
  productUrl   String
  imageUrl     String?
  price        Float? // Using Float for price in SQLite
  currency     String @default("USD") // Currency code (USD, EUR, GBP, etc.)
  variants     String? // e.g., "Size: M, Color: Black"
  platform     String // e.g., "Amazon"
  quantity     Int @default(1) // Quantity needed
  status       String @default("WISHED") // "WISHED", "ON_HOLD", "PURCHASED", "RECEIVED", "BOUGHT_SELF", "REMOVED"
  heldByUserId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  list       List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  heldByUser User? @relation(fields: [heldByUserId], references: [id], onDelete: SetNull)
  blocks     ItemBlock[]

  @@index([listId])
  @@index([heldByUserId])
  @@index([status])
}

model ItemBlock {
  id         String   @id @default(cuid())
  itemId     String
  userId     String
  createdAt  DateTime @default(now())

  item ListItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User     @relation("itemBlocks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId])
  @@index([userId])
}

model SocialActivity {
  id           String   @id @default(cuid())
  userId       String
  activityType String   // "NEW_LIST", "NEW_EVENT", "LIST_UPDATE"
  entityType   String   // "LIST", "EVENT"
  entityId     String
  entityName   String
  createdAt    DateTime @default(now())

  user User @relation("socialActivities", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([activityType])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Feedback {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  feedback  String
  rating    Int?     // 1-5 star rating
  category  String   @default("general") // "general", "feature", "bug", "ui", "performance"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([category])
}