generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  dob            DateTime?
  gender         String    @default("other")
  anniversary    DateTime?
  address        String?   // Stored as JSON string
  role           String    @default("USER")
  createdAt      DateTime  @default(now())

  accounts             Account[]
  sessions             Session[]
  lists                List[]
  events               Event[]
  friendshipsRequested Friendship[]    @relation("FriendshipRequester")
  friendshipsReceived  Friendship[]    @relation("FriendshipAddressee")
  notifications        Notification[]
  socialActivities     SocialActivity[]
  heldItems            ListItem[]      @relation("HeldByUser")
  itemBlocks           ItemBlock[]
}

// Required by @next-auth/prisma-adapter (field names are intentionally snake_case per OAuth spec)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Event {
  id          String   @id @default(cuid())
  userId      String
  name        String
  occasion    String?
  eventDate   DateTime
  description String?
  createdAt   DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lists List[]
}

model List {
  id        String   @id @default(cuid())
  userId    String
  eventId   String?
  name      String
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event?    @relation(fields: [eventId], references: [id])
  items ListItem[]
}

model ListItem {
  id           String   @id @default(cuid())
  listId       String
  productName  String
  productUrl   String
  imageUrl     String?
  price        Float?
  currency     String   @default("USD")
  variants     String?
  platform     String?
  quantity     Int      @default(1)
  status       String   @default("WISHED")
  heldByUserId String?
  createdAt    DateTime @default(now())

  list       List       @relation(fields: [listId], references: [id], onDelete: Cascade)
  heldByUser User?      @relation("HeldByUser", fields: [heldByUserId], references: [id])
  itemBlocks ItemBlock[]
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialActivity {
  id           String   @id @default(cuid())
  userId       String
  activityType String
  entityType   String?
  entityId     String?
  entityName   String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  feedback  String
  rating    Int?
  category  String   @default("general")
  createdAt DateTime @default(now())
}

model ItemBlock {
  id     String @id @default(cuid())
  itemId String
  userId String

  item ListItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}
